generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  fullName     String?
  role         Role          @default(USER)
  reservations Reservation[]
}

model Concert {
  id           String        @id @default(uuid())
  name         String
  description  String
  totalSeats   Int
  reservations Reservation[]
}

model Reservation {
  id        String   @id @default(uuid())
  userId    String
  concertId String
  action    String   @default("Reserve")
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  concert Concert @relation(fields: [concertId], references: [id])

  /* ป้องกันจองซ้ำ */
  @@unique([userId, concertId])
}

